# i3 config (v4)

bindsym $mod+Shift+r reload
bindsym $mod+Ctrl+r restart
bindsym $mod+h bar mode toggle

bindsym $mod+Ctrl+e mode "$mode_gaps"
bindsym $mod+q mode "$mode_system"
bindsym $mod+Shift+e mode "resize"

bindsym $mod+w kill

################################################################################################
# PROGRAMS
bindsym $mod+Ctrl+b exec terminal -e 'bmenu'
bindsym $mod+Return exec alacritty
bindsym $mod+Ctrl+h exec pavucontrol
bindsym $mod+r exec --no-startup-id dmenu_recency
bindsym $mod+g exec google-chrome-stable

bindsym $mod+Ctrl+r --release exec --no-startup-id xkill
# bindsym $mod+Shift+d --release exec "killall dunst; exec notify-send 'restart dunst'"

################################################################################################
# NAVIGATION
# change focus
bindsym $mod+m focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+m move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# toggle fullscreen mode for the focused container
bindsym $mod+e fullscreen toggle

################################################################################################
# WORKSPACES
set $ws1 1:a
set $ws2 2:s
set $ws3 3:d
set $ws4 4:f
set $ws5 5:i
set $ws6 6:o
set $ws7 7:u
set $ws8 8:steam
set $ws9 9:disc
set $ws10 10:spo

workspace 1:a output HDMI-0
workspace 2:s output HDMI-0
workspace 3:d output HDMI-0
workspace 4:f output HDMI-0
workspace 5:i output DVI-D-0
workspace 6:o output DVI-D-0
workspace 7:u output DVI-D-0
workspace 8:steam output DVI-D-0
workspace 9:disc output DVI-D-0
workspace 10:spo output DVI-D-0

# switch to workspace
bindsym $mod+a workspace $ws1
bindsym $mod+s workspace $ws2
bindsym $mod+d workspace $ws3
bindsym $mod+f workspace $ws4
bindsym $mod+i workspace $ws5
bindsym $mod+o workspace $ws6
bindsym $mod+u workspace $ws7
bindsym $mod+x workspace $ws8
bindsym $mod+c workspace $ws9
bindsym $mod+v workspace $ws10

# Move focused container to workspace
bindsym $mod+Ctrl+a move container to workspace $ws1
bindsym $mod+Ctrl+s move container to workspace $ws2
bindsym $mod+Ctrl+d move container to workspace $ws3
bindsym $mod+Ctrl+f move container to workspace $ws4
bindsym $mod+Ctrl+i move container to workspace $ws5
bindsym $mod+Ctrl+o move container to workspace $ws6
bindsym $mod+Ctrl+u move container to workspace $ws7
bindsym $mod+Ctrl+x move container to workspace $ws8
bindsym $mod+Ctrl+c move container to workspace $ws9
bindsym $mod+Ctrl+v move container to workspace $ws10

# Move to workspace with focused container
bindsym $mod+Shift+a move container to workspace $ws1; workspace $ws1
bindsym $mod+Shift+s move container to workspace $ws2; workspace $ws2
bindsym $mod+Shift+d move container to workspace $ws3; workspace $ws3
bindsym $mod+Shift+f move container to workspace $ws4; workspace $ws4
bindsym $mod+Shift+i move container to workspace $ws5; workspace $ws5
bindsym $mod+Shift+o move container to workspace $ws6; workspace $ws6
bindsym $mod+Shift+u move container to workspace $ws7; workspace $ws7
bindsym $mod+Shift+x move container to workspace $ws8; workspace $ws8
bindsym $mod+Shift+c move container to workspace $ws9; workspace $ws9
bindsym $mod+Shift+v move container to workspace $ws10; workspace $ws10

exec --no-startup-id setxkbmap -layout gfkl -variant qwerty -model pc105 -option altwin:swap_lalt_lwin
