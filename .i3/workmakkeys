# i3 config (v4)

bindsym $mod+Shift+m reload
bindsym $mod+Ctrl+m restart
bindsym $mod+p bar mode toggle

bindsym $mod+Ctrl+l mode "$mode_gaps"
bindsym $mod+q mode "$mode_system"
bindsym $mod+Shift+l mode "resize"

bindsym $mod+c kill

################################################################################################
# PROGRAMS
bindsym $mod+Ctrl+b exec terminal -e 'bmenu'
bindsym $mod+Return exec alacritty
bindsym $mod+Ctrl+p exec pavucontrol
bindsym $mod+m exec --no-startup-id dmenu_recency
bindsym $mod+g exec google-chrome-stable

bindsym $mod+Ctrl+p --release exec --no-startup-id xkill
# bindsym $mod+Shift+d --release exec "killall dunst; exec notify-send 'restart dunst'"

################################################################################################
# NAVIGATION
# change focus
bindsym $mod+h focus left
bindsym $mod+n focus down
bindsym $mod+e focus up
bindsym $mod+i focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+n move down
bindsym $mod+Shift+e move up
bindsym $mod+Shift+i move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# toggle fullscreen mode for the focused container
bindsym $mod+l fullscreen toggle

################################################################################################
# WORKSPACES
set $ws1 1:a
set $ws2 2:s
set $ws3 3:r
set $ws4 4:t
set $ws5 5:u
set $ws6 6:y
set $ws7 7:f
set $ws8 8:steam
set $ws9 9:disc
set $ws10 10:spo

workspace 1:a output HDMI-0
workspace 2:s output HDMI-0
workspace 3:r output HDMI-0
workspace 4:t output HDMI-0
workspace 5:u output DVI-D-0
workspace 6:y output DVI-D-0
workspace 7:f output DVI-D-0
workspace 8:steam output DVI-D-0
workspace 9:disc output DVI-D-0
workspace 10:spo output DVI-D-0

# switch to workspace
bindsym $mod+a workspace $ws1
bindsym $mod+s workspace $ws2
bindsym $mod+r workspace $ws3
bindsym $mod+t workspace $ws4
bindsym $mod+u workspace $ws5
bindsym $mod+y workspace $ws6
bindsym $mod+f workspace $ws7
bindsym $mod+w workspace $ws8
bindsym $mod+d workspace $ws9
bindsym $mod+j workspace $ws10

# Move focused container to workspace
bindsym $mod+Ctrl+a move container to workspace $ws1
bindsym $mod+Ctrl+s move container to workspace $ws2
bindsym $mod+Ctrl+r move container to workspace $ws3
bindsym $mod+Ctrl+t move container to workspace $ws4
bindsym $mod+Ctrl+u move container to workspace $ws5
bindsym $mod+Ctrl+y move container to workspace $ws6
bindsym $mod+Ctrl+f move container to workspace $ws7
bindsym $mod+Ctrl+w move container to workspace $ws8
bindsym $mod+Ctrl+d move container to workspace $ws9
bindsym $mod+Ctrl+j move container to workspace $ws10

# Move to workspace with focused container
bindsym $mod+Shift+a move container to workspace $ws1; workspace $ws1
bindsym $mod+Shift+s move container to workspace $ws2; workspace $ws2
bindsym $mod+Shift+r move container to workspace $ws3; workspace $ws3
bindsym $mod+Shift+t move container to workspace $ws4; workspace $ws4
bindsym $mod+Shift+u move container to workspace $ws5; workspace $ws5
bindsym $mod+Shift+y move container to workspace $ws6; workspace $ws6
bindsym $mod+Shift+f move container to workspace $ws7; workspace $ws7
bindsym $mod+Shift+w move container to workspace $ws8; workspace $ws8
bindsym $mod+Shift+d move container to workspace $ws9; workspace $ws9
bindsym $mod+Shift+j move container to workspace $ws10; workspace $ws10

exec --no-startup-id setxkbmap -layout gfkl -variant wokmok_lshift -model pc105 -option altwin:swap_lalt_lwin
exec xcape -e '#66=Escape;#23=Tab' -t 200
