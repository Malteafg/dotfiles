# i3 config (v4)

bindsym $mod+Shift+p reload
bindsym $mod+Ctrl+p restart
bindsym $mod+m bar mode toggle

bindsym $mod+Ctrl+h mode "$mode_gaps"
bindsym $mod+q mode "$mode_system"
bindsym $mod+Shift+h mode "resize"

bindsym $mod+c kill

################################################################################################
# PROGRAMS
bindsym $mod+Ctrl+b exec terminal -e 'bmenu'
bindsym $mod+Return exec alacritty
bindsym $mod+Ctrl+m exec pavucontrol
bindsym $mod+p exec --no-startup-id dmenu_recency
bindsym $mod+g exec google-chrome-stable

bindsym $mod+Shift+apostrophe exec pcmanfm
bindsym $mod+Ctrl+apostrophe exec pcmanfm_pkexec
bindsym $mod+Ctrl+p --release exec --no-startup-id xkill
# bindsym $mod+Shift+d --release exec "killall dunst; exec notify-send 'restart dunst'"

################################################################################################
# NAVIGATION
# change focus
bindsym $mod+l focus left
bindsym $mod+n focus down
bindsym $mod+e focus up
bindsym $mod+i focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# move focused window
bindsym $mod+Shift+l move left
bindsym $mod+Shift+n move down
bindsym $mod+Shift+e move up
bindsym $mod+Shift+i move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# toggle fullscreen mode for the focused container
bindsym $mod+h fullscreen toggle

################################################################################################
# WORKSPACES
set $ws1 1:a
set $ws2 2:s
set $ws3 3:r
set $ws4 4:t
set $ws5 5:f
set $ws6 6:u
set $ws7 7:y
set $ws8 8:disc
set $ws9 9:spo

workspace 5:f output DVI-D-0
workspace 6:u output DVI-D-0
workspace 7:y output DVI-D-0
workspace 8:disc output DVI-D-0
workspace 9:spo output DVI-D-0

# switch to workspace
bindsym $mod+a workspace $ws1
bindsym $mod+s workspace $ws2
bindsym $mod+r workspace $ws3
bindsym $mod+t workspace $ws4
bindsym $mod+f workspace $ws5
bindsym $mod+u workspace $ws6
bindsym $mod+y workspace $ws7
bindsym $mod+d workspace $ws8
bindsym $mod+v workspace $ws9

# Move focused container to workspace
bindsym $mod+Ctrl+a move container to workspace $ws1
bindsym $mod+Ctrl+s move container to workspace $ws2
bindsym $mod+Ctrl+r move container to workspace $ws3
bindsym $mod+Ctrl+t move container to workspace $ws4
bindsym $mod+Ctrl+f move container to workspace $ws5
bindsym $mod+Ctrl+u move container to workspace $ws6
bindsym $mod+Ctrl+y move container to workspace $ws7
bindsym $mod+Ctrl+d move container to workspace $ws8
bindsym $mod+Ctrl+v move container to workspace $ws9

# Move to workspace with focused container
bindsym $mod+Shift+a move container to workspace $ws1; workspace $ws1
bindsym $mod+Shift+s move container to workspace $ws2; workspace $ws2
bindsym $mod+Shift+r move container to workspace $ws3; workspace $ws3
bindsym $mod+Shift+t move container to workspace $ws4; workspace $ws4
bindsym $mod+Shift+f move container to workspace $ws5; workspace $ws5
bindsym $mod+Shift+u move container to workspace $ws6; workspace $ws6
bindsym $mod+Shift+y move container to workspace $ws7; workspace $ws7
bindsym $mod+Shift+d move container to workspace $ws8; workspace $ws8
bindsym $mod+Shift+v move container to workspace $ws9; workspace $ws9

exec --no-startup-id setxkbmap -layout gfkl -model pc105 -option altwin:swap_lalt_lwin
exec xcape -e '#66=Escape;#23=Tab' -t 200
