#!/bin/bash

fd -t f -H -I | fzf -m --preview="head -30 {}" --reverse | while read line ; do
    filetype=$(file --mime-type $line | awk '{print $NF}')
    case $filetype in
        text*)
            echo $line | xargs -ro -d "\n" vim
            ;;
        image*)
            echo $line | xargs -ro -d "\n" swallow sxiv
            ;;
        *)
            echo $line | xargs -ro -d "\n" xdg-open 2>&-
            ;;
    esac
done
