# i3 config (qwerty keys)

################################################################################################
# AUTOSTART
exec --no-startup-id setxkbmap -layout gfkl -variant qwerty -model pc105 -option altwin:swap_lalt_lwin

################################################################################################
# KEY BINDS
bindsym $mod+q mode "$mode_system"

bindsym $mod+w kill
bindsym $mod+Ctrl+w --release exec --no-startup-id xkill

bindsym $mod+e fullscreen toggle
bindsym $mod+Shift+e mode "resize"
bindsym $mod+Ctrl+e mode "$mode_gaps"

bindsym $mod+r exec --no-startup-id dmenu_recency
bindsym $mod+Shift+r exec ~/.config/i3/reloadconfig
bindsym $mod+Ctrl+r restart

bindsym $mod+Ctrl+t exec terminal -e 'bmenu'

bindsym $mod+h bar mode toggle
bindsym $mod+Ctrl+h exec pavucontrol

bindsym $mod+semicolon exec "alacritty -e of -h -E"

################################################################################################
# NAVIGATION
# change focus
bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

# move focused window
bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

################################################################################################
# WORKSPACES
# switch to workspace
bindsym $mod+a workspace number $ws1
bindsym $mod+s workspace number $ws2
bindsym $mod+d workspace number $ws3
bindsym $mod+f workspace number $ws4
bindsym $mod+i workspace number $ws5
bindsym $mod+o workspace number $ws6
bindsym $mod+u workspace number $ws7
bindsym $mod+x workspace number $ws8
bindsym $mod+c workspace number $ws9
bindsym $mod+v workspace number $ws10
bindsym $mod+z workspace number $ws11

# Move focused container to workspace
bindsym $mod+Ctrl+a move container to workspace number $ws1
bindsym $mod+Ctrl+s move container to workspace number $ws2
bindsym $mod+Ctrl+d move container to workspace number $ws3
bindsym $mod+Ctrl+f move container to workspace number $ws4
bindsym $mod+Ctrl+i move container to workspace number $ws5
bindsym $mod+Ctrl+o move container to workspace number $ws6
bindsym $mod+Ctrl+u move container to workspace number $ws7
bindsym $mod+Ctrl+x move container to workspace number $ws8
bindsym $mod+Ctrl+c move container to workspace number $ws9
bindsym $mod+Ctrl+v move container to workspace number $ws10
bindsym $mod+Ctrl+z move container to workspace number $ws11

# Move to workspace with focused container
bindsym $mod+Shift+a move container to workspace number $ws1; workspace number $ws1
bindsym $mod+Shift+s move container to workspace number $ws2; workspace number $ws2
bindsym $mod+Shift+d move container to workspace number $ws3; workspace number $ws3
bindsym $mod+Shift+f move container to workspace number $ws4; workspace number $ws4
bindsym $mod+Shift+i move container to workspace number $ws5; workspace number $ws5
bindsym $mod+Shift+o move container to workspace number $ws6; workspace number $ws6
bindsym $mod+Shift+u move container to workspace number $ws7; workspace number $ws7
bindsym $mod+Shift+x move container to workspace number $ws8; workspace number $ws8
bindsym $mod+Shift+c move container to workspace number $ws9; workspace number $ws9
bindsym $mod+Shift+v move container to workspace number $ws10; workspace number $ws10
bindsym $mod+Shift+z move container to workspace number $ws11; workspace number $ws11
