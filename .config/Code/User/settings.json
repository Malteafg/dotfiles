{
    "editor.lineNumbers": "relative",
    "keyboard.dispatch": "keyCode",
    "vim.insertModeKeyBindingsNonRecursive": [
        {
            "before": ["w", "f"], "after": ["<Esc>"]
        },
		{
			"before": ["f", "w"], "after": ["<Esc>"]
		}
    ],
    "vim.useSystemClipboard": true,
    "vim.handleKeys": {
        "<C-a>": false,
        "<C-f>": false
    }
}
